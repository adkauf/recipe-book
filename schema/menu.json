{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Menu",
    "description": "A planned menu: a single meal (e.g. Thanksgiving dinner) or a whole day of meals",
    "type": "object",
    "required": ["title", "meals"],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "title": {
            "type": "string",
            "examples": ["Thanksgiving Dinner", "Christmas Day"]
        },
        "subtitle": {
            "type": "string"
        },
        "description": {
            "type": "string"
        },
        "occasion": {
            "type": "string",
            "examples": ["Thanksgiving", "Christmas", "birthday", "potluck"]
        },
        "date": {
            "type": "string",
            "format": "date",
            "examples": ["2026-11-26"]
        },
        "guests": {
            "type": "integer",
            "minimum": 1,
            "description": "Number of people the menu should feed"
        },
        "notes": {
            "type": "array",
            "description": "Planning notes for the whole menu: make-ahead schedule, shopping reminders, dietary constraints.",
            "items": { "type": "string" },
            "minItems": 1
        },
        "meals": {
            "type": "array",
            "minItems": 1,
            "description": "Ordered list of meals. Use a single untitled meal for a one-meal menu; title them (Breakfast, Dinner) for a whole day.",
            "items": {
                "type": "object",
                "required": ["courses"],
                "properties": {
                    "title": {
                        "type": "string",
                        "description": "Meal name. Omit for a single-meal menu.",
                        "examples": ["Breakfast", "Lunch", "Dinner"]
                    },
                    "time": {
                        "type": "string",
                        "description": "When the meal is served, freeform.",
                        "examples": ["6:00 pm", "noon"]
                    },
                    "description": {
                        "type": "string"
                    },
                    "courses": {
                        "type": "array",
                        "minItems": 1,
                        "description": "Ordered list of courses. Use a single untitled course for an uncoursed meal.",
                        "items": {
                            "type": "object",
                            "required": ["dishes"],
                            "properties": {
                                "title": {
                                    "type": "string",
                                    "description": "Course name. Omit for an uncoursed meal.",
                                    "examples": ["Appetizers", "Main", "Sides", "Dessert"]
                                },
                                "description": {
                                    "type": "string"
                                },
                                "dishes": {
                                    "type": "array",
                                    "minItems": 1,
                                    "items": {
                                        "type": "object",
                                        "oneOf": [
                                            { "required": ["file"] },
                                            { "required": ["name"] }
                                        ],
                                        "properties": {
                                            "file": {
                                                "type": "string",
                                                "description": "Recipe filename stem, relative to data/recipes/ (e.g. 'sauerkraut'). Use for dishes with a recipe in the library."
                                            },
                                            "name": {
                                                "type": "string",
                                                "description": "Dish name for items without a recipe: store-bought, brought by a guest, or too simple to write up.",
                                                "examples": ["Dinner rolls (store-bought)", "Green salad"]
                                            },
                                            "note": {
                                                "type": "string",
                                                "description": "Note printed alongside this dish: who brings it, make-ahead timing, scaling.",
                                                "examples": ["double the recipe", "Aunt Sue brings this"]
                                            }
                                        },
                                        "additionalProperties": false
                                    }
                                }
                            },
                            "additionalProperties": false
                        }
                    }
                },
                "additionalProperties": false
            }
        }
    },
    "additionalProperties": false
}
