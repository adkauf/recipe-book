{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh .claude/hooks/validate-content.sh",
            "timeout": 60,
            "statusMessage": "Validating recipe JSON"
          }
        ]
      }
    ]
  }
}
